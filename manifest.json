{
  "manifest_version": 3,
  "name": "Salesforce Field Inspector",
  "version": "1.0.1",
  "description": "Hover over any field on a Salesforce record page to instantly see its API name, type, formula, lookup references, and more.",
  "permissions": ["clipboardWrite", "cookies", "management"],
  "background": {
    "service_worker": "background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.lightning.force.com/*",
    "https://*.force.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/lightning/*",
        "https://*.lightning.force.com/lightning/*",
        "https://*.force.com/lightning/*"
      ],
      "js": ["page_bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.salesforce.com/lightning/*",
        "https://*.lightning.force.com/lightning/*",
        "https://*.force.com/lightning/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Salesforce Field Inspector",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
